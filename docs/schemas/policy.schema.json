{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/saqreed/argusgate/docs/schemas/policy.schema.json",
  "title": "ArgusGate Policy",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": { "type": "string", "enum": ["0.1", "0.2", "0.3"] },
    "project": {
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "additionalProperties": false
    },
    "defaults": {
      "type": "object",
      "properties": {
        "fail_on": { "$ref": "#/$defs/failSeverity" },
        "allowed_severity": { "$ref": "#/$defs/severity" },
        "allow_unknown_tools": { "type": "boolean" },
        "allow_unknown_prompts": { "type": "boolean" },
        "allow_unknown_resources": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "rules": {
      "type": "object",
      "properties": {
        "allow_tools": { "$ref": "#/$defs/stringList" },
        "deny_tools": { "$ref": "#/$defs/stringList" },
        "allow_prompts": { "$ref": "#/$defs/stringList" },
        "deny_prompts": { "$ref": "#/$defs/stringList" },
        "deny_keywords": { "$ref": "#/$defs/stringList" },
        "paths": { "$ref": "#/$defs/pathRules" },
        "resource_uris": { "$ref": "#/$defs/pathRules" },
        "suppressions": {
          "type": "array",
          "maxItems": 1024,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/suppression" }
        }
      },
      "additionalProperties": false
    },
    "servers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/serverRule" }
    }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "failSeverity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "stringList": {
      "type": "array",
      "maxItems": 1024,
      "items": { "type": "string", "minLength": 1 }
    },
    "pathRules": {
      "type": "object",
      "properties": {
        "deny": { "$ref": "#/$defs/stringList" },
        "allow": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "serverRule": {
      "type": "object",
      "properties": {
        "allow_tools": { "$ref": "#/$defs/stringList" },
        "deny_tools": { "$ref": "#/$defs/stringList" },
        "allow_prompts": { "$ref": "#/$defs/stringList" },
        "deny_prompts": { "$ref": "#/$defs/stringList" },
        "resource_uris": { "$ref": "#/$defs/pathRules" }
      },
      "additionalProperties": false
    },
    "legacyServerRule": {
      "type": "object",
      "properties": {
        "allow_tools": { "$ref": "#/$defs/stringList" },
        "deny_tools": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "suppression": {
      "type": "object",
      "required": ["fingerprint", "reason"],
      "properties": {
        "fingerprint": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "reason": { "type": "string", "minLength": 1 },
        "expires": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "version": { "const": "0.1" } },
        "required": ["version"]
      },
      "then": {
        "properties": {
          "rules": {
            "not": { "required": ["suppressions"] }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "version": { "enum": ["0.1", "0.2"] } },
        "required": ["version"]
      },
      "then": {
        "properties": {
          "defaults": {
            "not": {
              "anyOf": [
                { "required": ["allow_unknown_prompts"] },
                { "required": ["allow_unknown_resources"] }
              ]
            }
          },
          "rules": {
            "not": {
              "anyOf": [
                { "required": ["allow_prompts"] },
                { "required": ["deny_prompts"] },
                { "required": ["resource_uris"] }
              ]
            }
          },
          "servers": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/legacyServerRule" }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
